{
  "name": "tawasol-whatslike",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,blue \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "lint": "npm run lint -w client",
    "build:client": "npm run build -w client",
    "start:server": "npm run start -w server",
    "docker:build": "docker build -t tawasol .",
    "docker:run": "docker run -p 4000:4000 --env-file .env.production --name tawasol-app tawasol"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
