NODE_ENV=production
PORT=4000
BIND_HOST=0.0.0.0
BASE_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app
PUBLIC_APP_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app
JWT_SECRET=replace-with-a-long-random-secret
MEDIA_SECRET=replace-with-another-long-random-secret
STORAGE_ROOT=/app/storage
