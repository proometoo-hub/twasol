NODE_ENV=production
PORT=4000
BASE_URL=https://twasol-production.up.railway.app
CORS_ORIGINS=https://twasol.vercel.app,https://*.vercel.app
JWT_SECRET=replace-with-a-long-random-secret
MEDIA_SECRET=replace-with-another-long-random-secret
MAX_UPLOAD_MB=80
MEDIA_LINK_TTL_SEC=86400
TRUST_PROXY=1

# PostgreSQL placeholder if you migrate later
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# Default admin account for first boot
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=548519
ADMIN_DISPLAY_NAME=Admin
