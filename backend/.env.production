# ============================================================
# Twasol Pro — Production Environment (Railway)
# ============================================================
# Copy this file to .env or set these as Railway environment variables

# Railway provides DATABASE_URL automatically when you add PostgreSQL plugin
DATABASE_URL="${DATABASE_URL}"

# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHARS"

# Railway sets PORT automatically
PORT="${PORT:-4000}"
BIND_HOST="0.0.0.0"

# Replace with your actual Railway backend URL
PUBLIC_APP_URL="https://YOUR-APP.up.railway.app"

# Replace with your actual Vercel frontend URL + Railway URL
ALLOWED_ORIGINS="https://YOUR-APP.vercel.app,https://YOUR-APP.up.railway.app,https://*.vercel.app"

ADMIN_EMAILS="your-email@example.com"
ALLOW_FIRST_USER_ADMIN="true"
ALLOW_PUBLIC_UPLOADS="false"

# Railway handles HTTPS via its proxy — do NOT enable HTTPS_ENABLED
HTTPS_ENABLED="false"
SERVE_FRONTEND_BUILD="false"

# Railway sits behind a reverse proxy
TRUST_PROXY_HOPS="1"
NODE_ENV="production"

# Optional AI features
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_TRANSLATE="gpt-4.1-mini"
OPENAI_MODEL_TRANSCRIBE="gpt-4o-mini-transcribe"
