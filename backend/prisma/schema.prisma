generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======= CORE MODELS =======

model User {
  id              Int      @id @default(autoincrement())
  publicId        String   @unique
  name            String
  email           String   @unique
  password        String
  avatar          String?
  animatedAvatar  String?
  coverPhoto      String?
  bio             String?  @default("")
  phone           String?  @default("")
  socialLinks     String?
  customStatus    String?
  statusEmoji     String?
  status          String?  @default("online")
  lastSeen        DateTime @default(now())
  hideLastSeen    String   @default("nobody")
  ghostMode       Boolean  @default(false)
  dndUntil        DateTime?
  chatBg          String?
  themeName       String   @default("dark")
  lockedPin       String?
  language        String   @default("ar")
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  expiresAt       DateTime?
  walletBalance   Float    @default(0)
  badges          String?
  createdAt       DateTime @default(now())
  // Relations
  sentMessages    Message[]  @relation("SentMessages")
  memberOf        ConversationMember[]
  stories         Story[]
  reactions       Reaction[]
  storyReactions  StoryReaction[]
  blockedBy       Block[]    @relation("Blocker")
  blockedUsers    Block[]    @relation("Blocked")
  invitesCreated  InviteLink[]
  quickReplies    QuickReply[]
  pollVotes       PollVote[]
  reports         Report[]   @relation("Reporter")
  reported        Report[]   @relation("Reported")
  auditLogs       AuditLog[]
  scheduledMsgs   ScheduledMessage[]
  sessions        Session[]
  joinRequests    JoinRequest[]
  starredMsgs     StarredMessage[]
  reminders       Reminder[]
  walletTxSent    WalletTx[] @relation("TxSender")
  walletTxRecv    WalletTx[] @relation("TxReceiver")
  storyHighlights StoryHighlight[]
  botOwned        Bot[]
  quizScores      QuizScore[]
  broadcastsOwned BroadcastList[]
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  device    String?
  ip        String?
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Block {
  id        Int      @id @default(autoincrement())
  userId    Int
  blockedId Int
  createdAt DateTime @default(now())
  user      User     @relation("Blocker", fields: [userId], references: [id])
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  @@unique([userId, blockedId])
  @@index([userId])
}

// ======= CONVERSATIONS =======

model Conversation {
  id             Int      @id @default(autoincrement())
  name           String?
  image          String?
  description    String?
  isGroup        Boolean  @default(false)
  isChannel      Boolean  @default(false)
  onlyAdmins     Boolean  @default(false)
  noMedia        Boolean  @default(false)
  noVoice        Boolean  @default(false)
  disappearAfter Int?
  welcomeMsg     String?
  chatTheme      String?
  requireApproval Boolean @default(false)
  folder         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       Message[]
  members        ConversationMember[]
  inviteLinks    InviteLink[]
  polls          Poll[]
  auditLogs      AuditLog[]
  scheduledMsgs  ScheduledMessage[]
  todos          Todo[]
  webhooks       Webhook[]
  products       Product[]
  calendarEvents CalendarEvent[]
  joinRequests   JoinRequest[]
}

model InviteLink {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  conversationId Int
  createdById    Int
  maxUses        Int?
  uses           Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdBy      User         @relation(fields: [createdById], references: [id])
  @@index([code])
}

model ConversationMember {
  id             Int          @id @default(autoincrement())
  userId         Int
  conversationId Int
  role           String       @default("member")
  tag            String?
  isMuted        Boolean      @default(false)
  muteNotifs     Boolean      @default(false)
  notifSound     String?
  canSendMedia   Boolean      @default(true)
  canSendVoice   Boolean      @default(true)
  isBanned       Boolean      @default(false)
  bannedReason   String?
  bannedAt       DateTime?
  joinedAt       DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

model JoinRequest {
  id             Int          @id @default(autoincrement())
  conversationId Int
  userId         Int
  status         String       @default("pending")
  note           String?
  createdAt      DateTime     @default(now())
  handledAt      DateTime?
  handledById    Int?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId, status])
}

// ======= MESSAGES =======

model Message {
  id             Int      @id @default(autoincrement())
  text           String?
  type           String   @default("text")
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  linkPreview    String?
  locationLat    Float?
  locationLng    Float?
  locationName   String?
  contactUserId  Int?
  animation      String?
  encryptedKey   String?
  fingerprint    String?
  senderId       Int
  conversationId Int
  replyToId      Int?
  forwardedFrom  Int?
  pollId         Int?
  isPinned       Boolean  @default(false)
  isRead         Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  isEdited       Boolean  @default(false)
  isSystem       Boolean  @default(false)
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  editedAt       DateTime?
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  replyTo        Message? @relation("Replies", fields: [replyToId], references: [id])
  replies        Message[] @relation("Replies")
  reactions      Reaction[]
  readReceipts   ReadReceipt[]
  starredBy      StarredMessage[]
  reminders      Reminder[]
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model ReadReceipt {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  @@unique([messageId, userId])
  @@index([messageId])
}

model Reaction {
  id        Int  @id @default(autoincrement())
  emoji     String
  userId    Int
  messageId Int
  user      User    @relation(fields: [userId], references: [id])
  message   Message @relation(fields: [messageId], references: [id])
  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model StarredMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  message   Message  @relation(fields: [messageId], references: [id])
  @@unique([userId, messageId])
  @@index([userId])
}

// ======= STORIES =======

model Story {
  id        Int      @id @default(autoincrement())
  userId    Int
  mediaUrl  String?
  text      String?
  type      String   @default("text")
  color     String?  @default("#005c4b")
  pollData  String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  reactions StoryReaction[]
  @@index([userId])
  @@index([expiresAt])
}

model StoryReaction {
  id      Int    @id @default(autoincrement())
  storyId Int
  userId  Int
  emoji   String
  story   Story  @relation(fields: [storyId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
  @@unique([storyId, userId])
}

model StoryHighlight {
  id       Int      @id @default(autoincrement())
  userId   Int
  name     String
  cover    String?
  storyIds String
  createdAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

// ======= POLLS & QUIZZES =======

model Poll {
  id             Int          @id @default(autoincrement())
  question       String
  conversationId Int
  createdById    Int
  isAnonymous    Boolean      @default(false)
  multiChoice    Boolean      @default(false)
  isQuiz         Boolean      @default(false)
  endsAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  options        PollOption[]
  @@index([conversationId])
}

model PollOption {
  id        Int        @id @default(autoincrement())
  text      String
  isCorrect Boolean    @default(false)
  pollId    Int
  poll      Poll       @relation(fields: [pollId], references: [id])
  votes     PollVote[]
}

model PollVote {
  id       Int        @id @default(autoincrement())
  userId   Int
  optionId Int
  user     User       @relation(fields: [userId], references: [id])
  option   PollOption @relation(fields: [optionId], references: [id])
  @@unique([userId, optionId])
}

model QuizScore {
  id        Int      @id @default(autoincrement())
  userId    Int
  quizId    Int
  score     Int
  total     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

// ======= PRODUCTIVITY =======

model QuickReply {
  id     Int    @id @default(autoincrement())
  text   String
  userId Int
  user   User   @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Todo {
  id             Int          @id @default(autoincrement())
  text           String
  isDone         Boolean      @default(false)
  assignedTo     Int?
  conversationId Int
  createdById    Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@index([conversationId])
}

model Reminder {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int?
  text      String?
  remindAt  DateTime
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  message   Message? @relation(fields: [messageId], references: [id])
  @@index([remindAt])
}

model CalendarEvent {
  id             Int          @id @default(autoincrement())
  title          String
  description    String?
  startAt        DateTime
  endAt          DateTime?
  isRecurring    Boolean      @default(false)
  conversationId Int
  createdById    Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@index([conversationId])
}

model ScheduledMessage {
  id             Int          @id @default(autoincrement())
  text           String?
  type           String       @default("text")
  fileUrl        String?
  fileName       String?
  scheduledAt    DateTime
  isSent         Boolean      @default(false)
  isRecurring    Boolean      @default(false)
  recurPattern   String?
  senderId       Int
  conversationId Int
  sender         User         @relation(fields: [senderId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@index([scheduledAt])
}

// ======= COMMERCE =======

model WalletTx {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  amount     Float
  note       String?
  type       String   @default("transfer")
  createdAt  DateTime @default(now())
  sender     User     @relation("TxSender", fields: [senderId], references: [id])
  receiver   User     @relation("TxReceiver", fields: [receiverId], references: [id])
  @@index([senderId])
}

model Product {
  id             Int          @id @default(autoincrement())
  name           String
  description    String?
  price          Float
  image          String?
  stock          Int          @default(0)
  conversationId Int
  createdById    Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  orders         ProductOrder[]
  @@index([conversationId])
}

model ProductOrder {
  id        Int      @id @default(autoincrement())
  productId Int
  buyerId   Int
  quantity  Int      @default(1)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  @@index([productId])
}

// ======= AUTOMATION =======

model Bot {
  id        Int      @id @default(autoincrement())
  name      String
  trigger   String
  response  String
  ownerId   Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id])
  @@index([ownerId])
}

model Webhook {
  id             Int          @id @default(autoincrement())
  name           String
  url            String
  secret         String?
  events         String
  conversationId Int
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@index([conversationId])
}

model BroadcastList {
  id        Int      @id @default(autoincrement())
  name      String
  userIds   String
  ownerId   Int
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id])
  @@index([ownerId])
}

// ======= ADMIN =======

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  reportedId Int
  reason     String
  details    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  reported   User     @relation("Reported", fields: [reportedId], references: [id])
}

model AuditLog {
  id             Int          @id @default(autoincrement())
  action         String
  details        String?
  userId         Int
  conversationId Int
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  @@index([conversationId])
}

// ======= STICKERS =======

model StickerPack {
  id       Int       @id @default(autoincrement())
  name     String
  ownerId  Int?
  isCustom Boolean   @default(false)
  stickers Sticker[]
}

model Sticker {
  id     Int         @id @default(autoincrement())
  url    String
  emoji  String?
  packId Int
  pack   StickerPack @relation(fields: [packId], references: [id])
  @@index([packId])
}
