DATABASE_URL="${{ Postgres.DATABASE_URL }}"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
BIND_HOST="0.0.0.0"
PUBLIC_APP_URL="https://your-backend.up.railway.app"
ALLOWED_ORIGINS="https://your-frontend.vercel.app"
ADMIN_EMAILS="admin@example.com"
ALLOW_FIRST_USER_ADMIN="false"
ALLOW_PUBLIC_UPLOADS="false"

# Optional AI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_TRANSLATE="gpt-4.1-mini"
OPENAI_MODEL_TRANSCRIBE="gpt-4o-mini-transcribe"

HTTPS_ENABLED="false"
SERVE_FRONTEND_BUILD="false"
