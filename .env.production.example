NODE_ENV=production
PORT=4000
BIND_HOST=0.0.0.0

# Replace with your public Railway domain after deployment
BASE_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app
PUBLIC_APP_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app

# Generate long random secrets before production use
JWT_SECRET=replace-with-a-long-random-secret
MEDIA_SECRET=replace-with-another-long-random-secret

# Optional: mount one Railway Volume and point STORAGE_ROOT to it
# Example mount path: /app/storage
STORAGE_ROOT=/app/storage

# App behavior
MAX_UPLOAD_MB=80
MEDIA_LINK_TTL_SEC=86400
ALLOW_PUBLIC_UPLOADS=false
TRUST_PROXY=1
TRUST_PROXY_HOPS=1

# Default admin account on first boot
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=548519
ADMIN_DISPLAY_NAME=Admin
