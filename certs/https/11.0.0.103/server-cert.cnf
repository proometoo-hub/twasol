[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = PS
ST = Local
L  = LAN
O  = Twasol Local Network
OU = Local HTTPS
CN = 11.0.0.103

[ req_ext ]
subjectAltName = @alt_names
extendedKeyUsage = serverAuth
keyUsage = digitalSignature, keyEncipherment

[ alt_names ]
DNS.1 = localhost
DNS.2 = chat-lan
DNS.3 = twasol-lan
IP.1  = 127.0.0.1
IP.2  = 11.0.0.103
